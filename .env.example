# Copy this file to .env and adjust values for your environment.

# ── Zookeeper ────────────────────────────────────────────────
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_EXTERNAL_PORT=2181

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BROKER_ID=1
KAFKA_EXTERNAL_PORT=9092
KAFKA_INTERNAL_PORT=29092
KAFKA_OFFSETS_REPLICATION_FACTOR=1

# ── smsrouter app ────────────────────────────────────────────
APP_PORT=8080
APP_LOG_LEVEL=DEBUG

# ── Kafka UI ─────────────────────────────────────────────────
KAFKA_UI_PORT=8090
